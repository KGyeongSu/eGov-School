<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xmlns:c="http://www.springframework.org/schema/c"
	xsi:schemaLocation="
			http://www.springframework.org/schema/beans 
			https://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- DAO -->
	<bean id="userDAO" class="com.school.dao.UserDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="scheduleDAO" class="com.school.dao.ScheduleDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="bonusCriteriaDAO"
		class="com.school.dao.BonusCriteriaDAOImpl" c:session-ref="sqlSession" />
	<bean id="testDAO" class="com.school.dao.TestDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="messageDAO" class="com.school.dao.MessageDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="lessonDAO" class="com.school.dao.LessonDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="certifiCateDAO"
		class="com.school.dao.CertifiCateDAOImpl" c:session-ref="sqlSession" />
	<bean id="classApplyDAO" class="com.school.dao.ClassApplyDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="examAnswerDAO" class="com.school.dao.ExamAnswerDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="examResultDAO" class="com.school.dao.ExamResultDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="progressDAO" class="com.school.dao.ProgressDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="reputationDAO" class="com.school.dao.ReputationDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="classDAO" class="com.school.dao.ClassDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="lecApplicationDAO"
		class="com.school.dao.LecApplicationDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="lecRecruitDAO" class="com.school.dao.LecRecruitDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="questionDAO" class="com.school.dao.QuestionDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="jobNoticeDAO" class="com.school.dao.JobNoticeDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="examNoticeDAO" class="com.school.dao.ExamNoticeDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="learningStatusDAO" class="com.school.dao.LearningStatusDAOImpl"
		c:session-ref="sqlSession"/>


	<!-- Attach DAO -->
	<bean id="examNoticeAttachDAO"
		class="com.school.dao.ExamNoticeAttachDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="jobNoticeAttachDAO"
		class="com.school.dao.JobNoticeAttachDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="lecRecruitAttachDAO"
		class="com.school.dao.LecRecruitAttachDAOImpl"
		c:session-ref="sqlSession" />
	<bean id="lessonAttachDAO"
		class="com.school.dao.LessonAttachDAOImpl" c:session-ref="sqlSession" />
	<bean id="messageAttachDAO"
		class="com.school.dao.MessageAttachDAOImpl" c:session-ref="sqlSession" />


	<!-- service -->
	<bean id="userService" class="com.school.service.UserServiceImpl">
		<constructor-arg index="0" ref="userDAO" />
	    <constructor-arg index="1" ref="encoder" />
	</bean>

	<bean id="classService"
		class="com.school.service.ClassServiceImpl" >
		<constructor-arg index="0" ref="classDAO" />
		<constructor-arg index="1" ref="lessonDAO" />
	</bean>
	<bean id="classApplyService" class="com.school.service.ClassApplyServiceImpl">
	    <constructor-arg index="0" ref="classApplyDAO" />
	    <constructor-arg index="1" ref="lessonDAO" />
	    <constructor-arg index="2" ref="learningStatusDAO" />
	    <constructor-arg index="3" ref="lessonAttachDAO" />
	</bean>
    
	<bean id="learningStatusService" class="com.school.service.LearningStatusServiceImpl" 
	    c:classApplyDAO-ref="classApplyDAO"
	    c:learningStatusDAO-ref="learningStatusDAO" />
	    
   <bean id="testService" class="com.school.service.TestServiceImpl">
      <constructor-arg index="0" ref="testDAO" />
      <constructor-arg index="1" ref="questionDAO" />
      <constructor-arg index="2" ref="examResultDAO" />
   </bean>

	

	<bean id="lessonService"
		class="com.school.service.LessonServiceImpl">
		<constructor-arg index="0" ref="lessonDAO" />
		<constructor-arg index="1" ref="lessonAttachDAO" />
	</bean>
	<bean id="jobNoticeService" class="com.school.service.JobNoticeServiceImpl"
	    c:jobNoticeDAO-ref="jobNoticeDAO" /> 
	<bean id="examNoticeService" class="com.school.service.ExamNoticeServiceImpl"
	    c:examNoticeDAO-ref="examNoticeDAO" />




		<!-- utils -->
		<bean id="fileUploadUtils"
			class="com.school.utils.FileUploadUtils" />


</beans>