<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="ExamNoticeAttach-Mapper">

	<select id="selectENAttachSeqNext" resultType="str">
		SELECT SEQ_EXAMNOTICE_ATTACH.NEXTVAL FROM DUAL
	</select>

	<insert id="insertENAttach" parameterType="enAttach">
		INSERT INTO EXAMNOTICE_ATTACH(ENA_NUM, EN_NUM, ENA_NAME, ENA_TYPE)
		VALUES(#{enaNum}, #{enNum}, #{enaName}, #{enaType})
	</insert>

	<select id="selectENAttachList" parameterType="str" resultType="enAttach">
		SELECT * FROM EXAMNOTICE_ATTACH
		WHERE EN_NUM = #{enNum}
		ORDER BY ENA_NUM ASC
	</select>

	<delete id="deleteENAttach" parameterType="str">
		DELETE FROM EXAMNOTICE_ATTACH
		WHERE ENA_NUM = #{enaNum}
	</delete>

	<delete id="deleteENAttachByParent" parameterType="str">
		DELETE FROM EXAMNOTICE_ATTACH
		WHERE EN_NUM = #{enNum}
	</delete>

</mapper>