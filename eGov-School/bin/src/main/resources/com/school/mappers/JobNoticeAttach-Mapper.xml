<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="JobNoticeAttach-Mapper">
 
	<select id="selectJNAttachSeqNext" resultType="str">
		SELECT SEQ_JOBNOTICE_ATTACH.NEXTVAL FROM DUAL
	</select>
 
	<insert id="insertJNAttach" parameterType="jnAttach">
		INSERT INTO JOBNOTICE_ATTACH(JNA_NUM, JN_NUM, JNA_NAME, JNA_TYPE)
		VALUES(#{jnaNum}, #{jnNum}, #{jnaName}, #{jnaType})
	</insert>
 
	<select id="selectJNAttachList" parameterType="str" resultType="jnAttach">
		SELECT * FROM JOBNOTICE_ATTACH
		WHERE JN_NUM = #{jnNum}
		ORDER BY JNA_NUM ASC
	</select>
 
	<delete id="deleteJNAttach" parameterType="str">
		DELETE FROM JOBNOTICE_ATTACH
		WHERE JNA_NUM = #{jnaNum}
	</delete>
 
	<delete id="deleteJNAttachByParent" parameterType="str">
		DELETE FROM JOBNOTICE_ATTACH
		WHERE JN_NUM = #{jnNum}
	</delete>
 
</mapper>