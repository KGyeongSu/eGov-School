<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="LessonAttach-Mapper">
 
	<select id="selectLessonAttachSeqNext" resultType="str">
		SELECT SEQ_LESSON_ATTACH.NEXTVAL FROM DUAL
	</select>
 
	<insert id="insertLessonAttach" parameterType="lessonAttach">
		INSERT INTO LESSON_ATTACH(LA_NUM, LSN_NUM, LA_NAME, LA_TYPE)
		VALUES(#{laNum}, #{lsnNum}, #{laName}, #{laType})
	</insert>
 
	<select id="selectLessonAttachList" parameterType="str" resultType="lessonAttach">
		SELECT * FROM LESSON_ATTACH
		WHERE LSN_NUM = #{lsnNum}
		ORDER BY LA_NUM ASC
	</select>
 
	<delete id="deleteLessonAttach" parameterType="str">
		DELETE FROM LESSON_ATTACH
		WHERE LA_NUM = #{laNum}
	</delete>
 
	<delete id="deleteLessonAttachByParent" parameterType="str">
		DELETE FROM LESSON_ATTACH
		WHERE LSN_NUM = #{lsnNum}
	</delete>
 
</mapper>