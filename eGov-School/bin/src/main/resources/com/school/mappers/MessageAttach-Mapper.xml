<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="MessageAttach-Mapper">
 
	<select id="selectMsgAttachSeqNext" resultType="str">
		SELECT SEQ_MESSAGE_ATTACH.NEXTVAL FROM DUAL
	</select>
 
	<insert id="insertMsgAttach" parameterType="msgAttach">
		INSERT INTO MESSAGE_ATTACH(MA_NUM, MS_NUM, MA_NAME, MA_TYPE)
		VALUES(#{maNum}, #{msNum}, #{maName}, #{maType})
	</insert>
 
	<select id="selectMsgAttachList" parameterType="str" resultType="msgAttach">
		SELECT * FROM MESSAGE_ATTACH
		WHERE MS_NUM = #{msNum}
		ORDER BY MA_NUM ASC
	</select>
 
	<delete id="deleteMsgAttach" parameterType="str">
		DELETE FROM MESSAGE_ATTACH
		WHERE MA_NUM = #{maNum}
	</delete>
 
	<delete id="deleteMsgAttachByParent" parameterType="str">
		DELETE FROM MESSAGE_ATTACH
		WHERE MS_NUM = #{msNum}
	</delete>
 
</mapper>