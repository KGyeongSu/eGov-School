<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	   xmlns:p="http://www.springframework.org/schema/p"
	   xmlns:c="http://www.springframework.org/schema/c"
	   xsi:schemaLocation="
			http://www.springframework.org/schema/beans 
			https://www.springframework.org/schema/beans/spring-beans.xsd" >
			
		<!-- DAO -->
		<bean id="userDAO"
			  class="com.school.dao.UserDAOImpl"
			  c:session-ref="sqlSession"
			  />
		<bean id="scheduleDAO"
			  class="com.school.dao.ScheduleDAOImpl"
			  c:session-ref="sqlSession"
			  />	
		<bean id="bonusCriteriaDAO"
			  class="com.school.dao.BonusCriteriaDAOImpl"
			  c:session-ref="sqlSession"
			  />
		<bean id="testDAO"
			  class="com.school.dao.TestDAOImpl"
			  c:session-ref="sqlSession"
			  />
		<bean id="messageDAO"
		      class="com.school.dao.MessageDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="lessonDAO"
		      class="com.school.dao.LessonDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="certifiCateDAO"
		      class="com.school.dao.CertifiCateDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="classApplyDAO"
		      class="com.school.dao.ClassApplyDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="examAnswerDAO"
		      class="com.school.dao.ExamAnswerDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="examResultDAO"
		      class="com.school.dao.ExamResultDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="progressDAO"
		      class="com.school.dao.ProgressDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="reputationDAO"
		      class="com.school.dao.ReputationDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="classDAO"
		      class="com.school.dao.ClassDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="lecApplicationDAO"
		      class="com.school.dao.LecApplicationDAOImpl"
		      c:session-ref="sqlSession"
		      />
		<bean id="lecRecruitDAO"
		      class="com.school.dao.LecRecruitDAOImpl"
		      c:session-ref="sqlSession"
		      />
